#!/usr/bin/env bash
set -euo pipefail

root="$(git rev-parse --show-toplevel)"
cd "$root"

output="$(
  AFK_WORKFLOW_MOCK_QUEUE=$'7\tScaffold shell\thttps://example.test/issues/7\tready-for-agent,afk\n8\tFloating avatar\thttps://example.test/issues/8\tready-for-agent,afk\n9\tMenu bar\thttps://example.test/issues/9\tready-for-agent,afk' \
    scripts/afk-workflow run --dry-run --concurrency 2 --max-waves 1
)"

grep -q "wave 1: selected issue #7" <<< "$output"
grep -q "wave 1: selected issue #8" <<< "$output"
if grep -q "selected issue #9" <<< "$output"; then
  echo "expected dry run to respect concurrency limit" >&2
  exit 1
fi

grep -q "dry-run: would claim issue #7" <<< "$output"
grep -q "dry-run: would run Ralph for issue #8" <<< "$output"
grep -q "dry-run: would review PR for issue #8" <<< "$output"

human_only_output="$(
  AFK_WORKFLOW_MOCK_QUEUE=$'10\tNeeds product call\thttps://example.test/issues/10\tready-for-agent\n11\tSafe cleanup\thttps://example.test/issues/11\tready-for-agent,afk' \
    scripts/afk-workflow run --dry-run --concurrency 2 --max-waves 1
)"

if grep -q "selected issue #10" <<< "$human_only_output"; then
  echo "expected AFK workflow to skip issues without afk label" >&2
  exit 1
fi
grep -q "wave 1: selected issue #11" <<< "$human_only_output"

blocked_output="$(
  AFK_WORKFLOW_MOCK_QUEUE=$'7\tScaffold shell\thttps://example.test/issues/7\tready-for-agent,afk\n8\tFloating avatar\thttps://example.test/issues/8\tready-for-agent,afk\n9\tMenu bar\thttps://example.test/issues/9\tready-for-agent,afk' \
  AFK_WORKFLOW_MOCK_BLOCKERS=$'8\t7' \
  AFK_WORKFLOW_MOCK_OPEN_ISSUES="7,8,9" \
    scripts/afk-workflow run --dry-run --concurrency 2 --max-waves 1 2>&1
)"

grep -q "wave 1: selected issue #7" <<< "$blocked_output"
if grep -q "selected issue #8" <<< "$blocked_output"; then
  echo "expected AFK workflow to skip issues blocked by open issues" >&2
  exit 1
fi
grep -q "skipping issue #8: blocked by open issue #7" <<< "$blocked_output"
grep -q "wave 1: selected issue #9" <<< "$blocked_output"

tmp_dir="$(mktemp -d)"
trap 'rm -rf "$tmp_dir"' EXIT
mkdir -p "$tmp_dir/bin"

cat >"$tmp_dir/bin/git" <<'SH'
#!/usr/bin/env bash
set -euo pipefail

if [[ "${1:-}" == "-C" ]]; then
  shift 2
fi

case "${1:-}" in
  rev-parse)
    printf '%s\n' "$TEST_REPO_ROOT"
    ;;
  status)
    exit 0
    ;;
  fetch|switch|pull)
    exit 0
    ;;
  *)
    echo "unexpected git command: $*" >&2
    exit 1
    ;;
esac
SH

cat >"$tmp_dir/bin/gh" <<'SH'
#!/usr/bin/env bash
set -euo pipefail

if [[ "$1 $2" == "pr view" ]]; then
  cat <<'JSON'
{"number":19,"title":"Handle blocked AFK issues","url":"https://example.test/pull/19","headRefName":"codex/issue-17-afk-blocked-issues","baseRefName":"main","state":"OPEN"}
JSON
  exit 0
fi

echo "unexpected gh command: $*" >&2
exit 1
SH

cat >"$tmp_dir/bin/codex" <<'SH'
#!/usr/bin/env bash
set -euo pipefail

output_file=""
last_arg=""
for arg in "$@"; do
  if [[ "$last_arg" == "-o" || "$last_arg" == "--output-last-message" ]]; then
    output_file="$arg"
  fi
  last_arg="$arg"
done

if [[ "${@: -1}" != "-" ]]; then
  echo "expected review prompt to be read from stdin with '-'" >&2
  exit 64
fi

prompt="$(cat)"
grep -q "Review exactly one pull request: #19." <<< "$prompt"
[[ -n "$output_file" ]] || { echo "missing output file argument" >&2; exit 65; }
mkdir -p "$(dirname "$output_file")"
printf 'review ok\nBEGIN_REVIEW_FIX_ISSUES_JSON\n{"fix_issues":[]}\nEND_REVIEW_FIX_ISSUES_JSON\n' >"$output_file"
SH

chmod +x "$tmp_dir/bin/git" "$tmp_dir/bin/gh" "$tmp_dir/bin/codex"

review_output="$tmp_dir/review.md"
PATH="$tmp_dir/bin:$PATH" TEST_REPO_ROOT="$root" \
  scripts/review-pr --pr 19 --output "$review_output" >/dev/null
grep -q "BEGIN_REVIEW_FIX_ISSUES_JSON" "$review_output"

mock_ralph="${tmp_dir}/mock-ralph-loop"
cat >"$mock_ralph" <<'MOCK_RALPH'
#!/usr/bin/env bash
set -euo pipefail

[[ "${1:-}" == "run" ]] || exit 2

issue=""
skip_base_refresh="0"
while [[ $# -gt 0 ]]; do
  case "$1" in
    --issue)
      issue="${2:-}"
      shift 2
      ;;
    --skip-base-refresh)
      skip_base_refresh="1"
      shift
      ;;
    --engine|--base)
      shift 2
      ;;
    run)
      shift
      ;;
    *)
      shift
      ;;
  esac
done

[[ "$skip_base_refresh" == "1" ]] || {
  echo "expected AFK workflow to run Ralph without switching the shared base branch" >&2
  exit 1
}

if git symbolic-ref -q --short HEAD >/dev/null; then
  echo "expected worker checkout to remain detached" >&2
  exit 1
fi

echo "started ${issue}" >> "${AFK_WORKFLOW_MOCK_STARTED_FILE:?}"
MOCK_RALPH
chmod +x "$mock_ralph"

started_file="${tmp_dir}/started"
mock_worker_output="$(
  AFK_WORKFLOW_MOCK_QUEUE=$'12\tConcurrent one\thttps://example.test/issues/12\tready-for-agent,afk\n13\tConcurrent two\thttps://example.test/issues/13\tready-for-agent,afk' \
  AFK_WORKFLOW_MOCK_WORKER=1 \
  AFK_WORKFLOW_MOCK_STARTED_FILE="$started_file" \
  AFK_WORKFLOW_RALPH_CMD="$mock_ralph" \
    scripts/afk-workflow run --concurrency 2 --max-waves 1 --base main
)"

grep -q "worker 1: issue #12 mock Ralph completed" <<< "$mock_worker_output"
grep -q "worker 2: issue #13 mock Ralph completed" <<< "$mock_worker_output"
grep -q "started 12" "$started_file"
grep -q "started 13" "$started_file"

echo "afk workflow tests passed"
