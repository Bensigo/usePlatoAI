{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "usePlatoAI",
  "version": "0.0.0",
  "identifier": "com.useplatoai.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "usePlatoAI",
        "width": 900,
        "height": 640,
        "minWidth": 360,
        "minHeight": 480,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
